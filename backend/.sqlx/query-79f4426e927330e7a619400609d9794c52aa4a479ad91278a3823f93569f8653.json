  "db_name": "PostgreSQL",
  "query": "\n            UPDATE runs\n               SET sandbox_id       = $2,\n                   sandbox_hostname = $3,\n                   session_id       = $4,\n                   command_id       = $5,\n                   branch           = $6,\n                   status           = $7,\n                   commit_title     = $8,\n                   commit_body      = $9,\n                   updated_at       = NOW()\n             WHERE id = (\n                 SELECT id FROM runs\n                  WHERE task_id = $1\n                  ORDER BY created_at DESC\n                  LIMIT 1\n             )\n            RETURNING *\n            ",
