  "query": "\n            SELECT id, task_id, run_id, log_line as \"log_line: serde_json::Value\", created_at\n            FROM task_logs\n            WHERE task_id = $1 AND ($2::BIGINT IS NULL OR id > $2)\n            ORDER BY id ASC\n            LIMIT 100\n            ",
