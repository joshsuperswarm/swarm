# Database configuration
DATABASE_URL=postgresql://swarm:password@localhost:5432/swarm

# Clerk authentication (get from Clerk Dashboard)
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Optional: GitHub token for fallback repository access
GITHUB_TOKEN=your_github_personal_access_token_here

# Server configuration
PORT=3001

# Daytona Cloud configuration (for AI workspace management)
DAYTONA_URL=https://app.daytona.io/api
DAYTONA_API_KEY=your_daytona_api_key_here
DAYTONA_ORGANIZATION_ID=your_organization_id_here
DAYTONA_REGION=us

# Logging configuration (optional)
RUST_LOG=info,swarm_backend=debug