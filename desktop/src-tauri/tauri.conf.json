{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "beforeBuildCommand": "cd frontend && bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/32x32@2x.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512@2x.png",
      "icons/1024x1024.png"
    ],
    "resources": []
  },
  "identifier": "com.swarm.app",
  "productName": "Swarm",
  "mainBinaryName": "swarm",
  "version": "0.1.0",
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Swarm",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
