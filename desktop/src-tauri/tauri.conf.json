{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "cd frontend && bun run dev",
    "beforeBuildCommand": "cd frontend && bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "com.repochat.app",
    "resources": []
  },
  "productName": "RepoChat",
  "mainBinaryName": "repochat",
  "version": "0.1.0",
  "identifier": "com.repochat.app",
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "RepoChat",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}